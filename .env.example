# Ключ Google Gemini API (обязателен для AI-функций)
# Получить: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=ваш_ключ_здесь

# Порт HTTP-сервера (по умолчанию 5000)
# PORT=5000
